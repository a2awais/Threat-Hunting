// Hunt curl or wget downloading .tar.gz archives directly into writable temp directories.

#event_simpleName = ProcessRollup2
| ImageFileName = /\b(curl|wget)\b/i
| CommandLine = /\.tar\.gz/i
| CommandLine = /\/var\/tmp|\/tmp|\/dev\/shm/i
| groupBy([ComputerName, UserName, CommandLine, ImageFileName, ParentBaseFileName],
    function=([count(aid, as=EventCount), min(@timestamp, as=FirstSeen), max(@timestamp, as=LastSeen)]))
| FirstSeen := formatTime("%Y-%m-%d %H:%M:%S", field=FirstSeen)
| sort(LastSeen, order=desc)
